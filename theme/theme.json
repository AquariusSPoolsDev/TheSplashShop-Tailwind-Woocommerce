					"color": "#0F172A",
					"name": "Foreground"
				},
				{
					"slug": "primary",
					"color": "#02BAE9",
					"name": "Primary"
				},
				{
					"slug": "primary-dark",
					"color": "#007DA1",
					"name": "Primary Dark"
				},
				{
					"slug": "primary-light",
					"color": "#E0F7FE",
					"name": "Primary Light"
				},
				{
					"slug": "secondary",
					"color": "#1E293B",
					"name": "Secondary"
				},
				{
					"slug": "secondary-dark",
					"color": "#0F172A",
					"name": "Secondary Dark"
				},
				{
					"slug": "secondary-light",
					"color": "#F1F5F9",
